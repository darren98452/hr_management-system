rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: either has admin role in users collection OR is the bootstrap email
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'darrenraj254@gmail.com'
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity Validations
    function isValidEmployee(data) {
      let requiredFields = ['name', 'email', 'status', 'departmentId', 'role', 'joiningDate'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.status in ['active', 'inactive', 'on-leave'] &&
             data.departmentId is string &&
             data.role is string &&
             (data.get('phoneNumber', '') is string);
    }

    function isValidDepartment(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidAttendance(data) {
      return data.employeeId is string &&
             data.date is string &&
             data.status in ['present', 'absent', 'late', 'half-day'];
    }

    function isValidLeaveRequest(data) {
      return data.employeeId is string &&
             data.type in ['sick', 'vacation', 'emergency', 'maternity', 'paternity'] &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // Rules
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && (
        incoming().role == 'employee' || 
        request.auth.token.email == 'darrenraj254@gmail.com'
      );
      allow update: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidEmployee(incoming());
      allow delete: if isAdmin();
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidDepartment(incoming());
      allow delete: if isAdmin();
    }

    match /attendance/{atId} {
      // allow read: if isSignedIn(); <- Restricted for PII isolation/Relational check
      allow read: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow create, update: if isAdmin() && isValidAttendance(incoming());
    }

    match /leave_requests/{requestId} {
      // allow read: if isSignedIn(); <- Strict list query enforcement
      allow read: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      
      allow create: if isSignedIn() && 
                      isOwner(incoming().employeeId) && 
                      isValidLeaveRequest(incoming()) && 
                      incoming().status == 'pending';
                      
      allow update: if isSignedIn() && (
        (isAdmin() && isValidLeaveRequest(incoming())) || 
        (isOwner(existing().employeeId) && 
         existing().status == 'pending' && 
         incoming().status == 'pending' && 
         isValidLeaveRequest(incoming()))
      );
      
      allow delete: if isSignedIn() && (
        isAdmin() || 
        (isOwner(existing().employeeId) && existing().status == 'pending')
      );
    }
  }
}
